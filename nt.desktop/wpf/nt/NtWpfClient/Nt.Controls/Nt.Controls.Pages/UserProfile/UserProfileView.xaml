<UserControl x:Class="Nt.Controls.Pages.UserProfile.UserProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Nt.Controls.Pages.UserProfile"
             mc:Ignorable="d" 
             xmlns:viewmodels="clr-namespace:Nt.Controls.Pages.UserProfile"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <viewmodels:UserProfileViewModel />
    </UserControl.DataContext>
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="1" Grid.Column="0" Content="UserName"/>
            <Label Grid.Row="1" Grid.Column="0" Content="{Binding UserName}"/>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="1" Grid.Column="0" Content="DisplayName"/>
            <Label Grid.Row="1" Grid.Column="0" Content="{Binding DisplayName}"/>
        </Grid>
    </StackPanel>
</UserControl>
